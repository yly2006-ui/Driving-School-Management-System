<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mashang.mashangdriving.mapper.manager.DrivingLocationMapper">
    <resultMap id="DrivingLocationListVoResult" type="DrivingLocationListVo">
        <id property="locationId" column="location_id"/>
        <result property="locationName" column="location_name"/>
        <result property="locationNo" column="location_no"/>
        <result property="locationTypeId" column="location_type_id"/>
        <result property="master" column="master"/>
        <result property="phoneNum" column="phone_num"/>
        <result property="status" column="status"/>
        <result property="address" column="address"/>
        <result property="province" column="province"/>
        <result property="city" column="city"/>
        <result property="county" column="county"/>
        <result property="remark" column="remark"/>
        <result property="capacity" column="capacity"/>
    </resultMap>

    <!-- 查询所有地点（用于分页） -->
    <select id="query" resultMap="DrivingLocationListVoResult">
        SELECT
            dl.location_id,
            dl.location_name,
            dl.location_no,
            dl.location_type_id,
            dl.master,
            dl.phone_num,
            dl.status,
            dl.address,
            dl.remark,
            dl.capacity,

            province.name AS province,
            city.name AS city,
            county.name AS county
        FROM driving_location dl
                 LEFT JOIN area county ON county.id = dl.area_id
                 LEFT JOIN area city ON city.id = county.parent_id
                 LEFT JOIN area province ON province.id = city.parent_id
        <!-- 关键：拼接 wrapper 条件 -->
        ${ew.customSqlSegment}
    </select>
</mapper>