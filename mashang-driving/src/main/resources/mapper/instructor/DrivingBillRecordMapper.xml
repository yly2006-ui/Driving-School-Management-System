    <select id="queryAnnualTotalIncome"
            resultType="com.mashang.mashangdriving.domain.vo.manager.DrivingBillYearMessageVo">
        -- 这是查询收入
        SELECT
            SUM( c.amount) annual_total_income
        FROM driving_charge_ltem c
                 LEFT JOIN driving_bill_record b
                           ON c.charge_ltem_id=b.charge_ltem_id
                 LEFT JOIN driving_pay p
                           ON p.pay_id=b.pay_id
        <!-- ${ew.customSqlSegment}这个是固定写法一定要加，不然条件就无效了 -->
        ${ew.customSqlSegment}
--         WHERE
--             b.role_id = 102
    </select>
    <select id="queryAnnualTotalExpenditure"
            resultType="com.mashang.mashangdriving.domain.vo.manager.DrivingBillYearMessageVo">
        -- 支出
        SELECT
            SUM( c.amount) annual_total_expenditure
        FROM driving_charge_ltem c
                 LEFT JOIN driving_bill_record b
                           ON c.charge_ltem_id=b.charge_ltem_id
                 LEFT JOIN driving_pay p
                           ON p.pay_id=b.pay_id
        <!-- ${ew.customSqlSegment}这个是固定写法一定要加，不然条件就无效了 -->
        ${ew.customSqlSegment}
--         WHERE
--             b.role_id = 101
    </select>
    <select id="queryAllStudentCount"
            resultType="com.mashang.mashangdriving.domain.vo.manager.DrivingBillYearMessageVo">
        SELECT COUNT(*) total_students
        FROM driving_student s
        LEFT JOIN driving_bill_record b
        ON b.user_id=s.user_id
        <!-- ${ew.customSqlSegment}这个是固定写法一定要加，不然条件就无效了 -->
        ${ew.customSqlSegment}
    </select>
